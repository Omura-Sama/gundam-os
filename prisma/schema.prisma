// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model CoreUser {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  role      String   @default("STAFF")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relasi ke tabel hybrid SystemRecord
  records   SystemRecord[]

  @@map("core_users")
}

// --- HYBRID ARMOR ENTITY ---
// Model polymorphic untuk menyimpan data dari berbagai macam modul (Striker Packs)
model SystemRecord {
  id          String   @id @default(uuid())
  
  // Hardpoints (Identifikasi Modul & Tipe Data)
  moduleName  String   // ex: 'BeamRifle', 'PatientData', 'Inventory'
  recordType  String   // ex: 'Transaction', 'MasterItem', 'Profile'
  
  // Ownership
  ownerId     Int?     // Mengacu ke CoreUser.id (optional jika data sistem)
  owner       CoreUser? @relation(fields: [ownerId], references: [id])
  
  // Psycho-Frame (Data Fleksibel JSON)
  payload     Json
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Indexing untuk mempercepat pencarian spesifik per-modul
  @@index([moduleName, recordType])
  @@index([ownerId])
  @@map("system_records")
}
