generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- INNER FRAME (CORE) ---
model CoreUser {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String
  isSuperAdmin  Boolean  @default(false) // Pilot Pusat Kontrol
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relasi ke Modul (Satu user bisa punya banyak peran)
  employeeData  HrEmployee?
  patientData   MedicalRecord?

  @@map("core_users")
}

// --- STRIKER PACK: HR MODULE (BACK OFFICE) ---
model HrEmployee {
  id           Int      @id @default(autoincrement())
  coreUserId   Int      @unique
  employeeCode String   @unique // Misal: NIP-2026-001
  department   String
  
  user         CoreUser @relation(fields: [coreUserId], references: [id], onDelete: Cascade)

  @@map("mod_hr_employees")
}

// --- STRIKER PACK: CLINIC MODULE (FRONT OFFICE) ---
model MedicalRecord {
  id           Int      @id @default(autoincrement())
  coreUserId   Int      @unique
  rmNumber     String   @unique // Misal: RM-99812
  bloodType    String?
  
  user         CoreUser @relation(fields: [coreUserId], references: [id], onDelete: Cascade)

  @@map("mod_medical_records")
}
